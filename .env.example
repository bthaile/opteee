# At least one LLM provider is required (API key or Ollama)

# Provider and model selection (optional - used as defaults)
# LLM_PROVIDER=claude
# LLM_MODEL=claude-haiku-4-5
# DEFAULT_EFFORT=low
# DEFAULT_MODEL_LOW=claude-haiku-4-5
# DEFAULT_MODEL_MEDIUM=claude-sonnet-4-5
# OPENAI_MODEL_LOW=gpt-4.1-mini
# OPENAI_MODEL_MEDIUM=gpt-4.1
# CLAUDE_MODEL_LOW=claude-haiku-4-5
# CLAUDE_MODEL_MEDIUM=claude-sonnet-4-5
# OLLAMA_MODEL_LOW=gemma4:e4b
# OLLAMA_MODEL_MEDIUM=gemma4:e4b
# OLLAMA_MODEL=gemma4:e4b
# OLLAMA_FALLBACK_MODELS=gemma4:e4b,gemma2:2b,llama3.2,mistral
# Models that don't support temperature (extend built-in list):
# OLLAMA_NO_TEMPERATURE_MODELS=gemma3:270m

# API keys (for openai / claude)
# CLAUDE_API_KEY=your-anthropic-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# Ollama (local or remote) - no API key needed
# OLLAMA_BASE_URL=http://m1pro.home:11434

# Timeout and fallback (primary times out after 60s, then try fallback)
# LLM_TIMEOUT_SECONDS=60
# LLM_FALLBACK_PROVIDER=ollama

DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/opteee
